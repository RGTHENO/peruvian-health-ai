SALUDPE_ENVIRONMENT=development
SALUDPE_DEBUG=true
SALUDPE_DATABASE_URL=sqlite+pysqlite:///./saludpe.db
SALUDPE_SECRET_KEY=change-this-in-production-32-bytes-minimum
SALUDPE_ACCESS_TOKEN_EXPIRE_MINUTES=30
SALUDPE_REFRESH_TOKEN_EXPIRE_DAYS=30
SALUDPE_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:4173","http://127.0.0.1:4173"]
SALUDPE_FRONTEND_URL=http://localhost:8080
SALUDPE_SEED_DEMO_DATA=true
